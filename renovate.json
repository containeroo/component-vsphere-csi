{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "ignorePaths": [".github/**"],
  "labels": ["dependency"],
  "packageRules": [
    {
      "description": "Keep vSphere CSI syncer and sidecars aligned to the upstream bundled release",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "registry.k8s.io/csi-vsphere/syncer",
        "registry.k8s.io/sig-storage/csi-attacher",
        "registry.k8s.io/sig-storage/csi-node-driver-registrar",
        "registry.k8s.io/sig-storage/csi-provisioner",
        "registry.k8s.io/sig-storage/csi-resizer",
        "registry.k8s.io/sig-storage/csi-snapshotter",
        "registry.k8s.io/sig-storage/livenessprobe"
      ],
      "enabled": false
    }
  ],
  "separateMinorPatch": true,
  "suppressNotifications": ["artifactErrors"],
  "postUpgradeTasks": {
    "commands": ["make sync-release", "make gen-golden-all"],
    "fileFilters": [
      "class/defaults.yml",
      "docs/modules/ROOT/pages/references/parameters.adoc",
      "tests/golden/**"
    ],
    "executionMode": "update"
  }
}
